# Judge0 CE API Configuration
# Free, no API key required
# Optional: Custom Judge0 API URL (default: https://ce.judge0.com)
JUDGE0_API_URL=https://ce.judge0.com

# Optional: Timeout in milliseconds (default: 30000 = 30 seconds)
JUDGE0_TIMEOUT=30000

# Optional: Maximum retries for failed requests (default: 3)
JUDGE0_MAX_RETRIES=3

# Server Configuration
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://neondb_owner:password@host/database?sslmode=require